_nan = np.isnan(_eta_for_ma)
if _nan.any() and (~_nan).sum() > 2:
    # Only bridge gaps ≤ CLIP.INTERP_MAX_GAP consecutive NaN samples
    _idx = np.arange(len(_eta_for_ma))
    _valid = ~_nan
    _filled = np.interp(_idx, _idx[_valid], _eta_for_ma[_valid])
    # Re-apply NaN for long runs (not a single spike) to avoid hiding real data loss
    # Build a mask: keep interpolation only where gap length ≤ INTERP_MAX_GAP
    from itertools import groupby
    _pos = 0
    for is_nan_run, group in groupby(_nan):
        run_len = sum(1 for _ in group)
        if is_nan_run and run_len > CLIP.INTERP_MAX_GAP:
            _filled[_pos:_pos + run_len] = np.nan
        _pos += run_len
    _eta_for_ma = _filled
df[ma_col] = (pd.Series(_eta_for_ma, index=df.index)
              .rolling(window=win, center=False).mean())
