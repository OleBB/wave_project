   629→    range_plot = prosessering.get("range_plot", False)
   630→
   631→    # Derive cfg once for the whole folder (all files share the same configuration)
   632→    file_date = datetime.fromisoformat(str(meta_sel["file_date"].iloc[0]))
   633→    cfg = get_configuration_for_date(file_date)
   634→
   635→    # 1. Ensure stillwater levels are computed
   636→    meta_full = ensure_stillwater_columns(dfs, meta_full, cfg)
   637→    stillwater = _extract_stillwater_levels(meta_full, cfg, debug)
   638→
   639→    # 2. Process dataframes: zero and add moving averages
   640→    processed_dfs = _zero_and_smooth_signals(dfs, meta_sel, stillwater, cfg, win, debug)
   641→    
   642→    # 3. Optional: find wave ranges
   643→    if find_range:
   644→        meta_sel = run_find_wave_ranges(processed_dfs, meta_sel, cfg, win, range_plot, debug)
   645→    
   646→    # 4. a - Compute PSDs and amplitudes from PSD (wave runs only)
   647→    psd_dict, amplitudes_psd_df = compute_psd_with_amplitudes(processed_dfs, meta_sel, cfg, fs=fs, debug=debug)
   648→
   649→    # 4. a2 - Broadband PSD for nowave runs (wind-only + stillwater), merged into psd_dict
   650→    _meta_nowave = meta_sel[meta_sel["WaveFrequencyInput [Hz]"].isna()]
   651→    if not _meta_nowave.empty:
   652→        psd_dict.update(compute_nowave_psd(processed_dfs, _meta_nowave, cfg, fs=fs))
   653→
   654→    # 4. b - compute FFT and amplitudes from FFT
   655→    fft_dict, amplitudes_fft_df = compute_fft_with_amplitudes(processed_dfs, meta_sel, cfg, fs=fs, debug=debug)
   656→
   657→    # 5. Compute and update all metrics (amplitudes, wavenumbers, dimensions, windspeed)
   658→    meta_sel = _update_all_metrics(processed_dfs, meta_sel, stillwater, amplitudes_psd_df, amplitudes_fft_df, cfg)
   659→
   660→    # 6. Set output folder and save metadata
   661→    meta_sel = _set_output_folder(meta_sel, meta_full, debug)
   662→
   663→    update_processed_metadata(meta_sel, force_recompute=force_recompute)
   664→
   665→    if debug:
